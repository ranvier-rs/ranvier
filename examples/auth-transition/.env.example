# JWT Secret Key
# In production, use a strong random secret (e.g., openssl rand -base64 32)
JWT_SECRET=default-secret-key

# Example Test Token (admin role)
# Generated with user_id="alice", roles=["admin", "user"]
# Valid for 24 hours from generation
# To create your own:
#   cargo test --package auth-transition
#   Or use https://jwt.io/ with HS256 algorithm
TEST_TOKEN_ADMIN=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJhbGljZSIsInJvbGVzIjpbImFkbWluIiwidXNlciJdLCJleHAiOjE3NDE3MTg0MDB9.example

# Example Test Token (user role only, no admin)
# Generated with user_id="bob", roles=["user"]
TEST_TOKEN_USER=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJib2IiLCJyb2xlcyI6WyJ1c2VyIl0sImV4cCI6MTc0MTcxODQwMH0.example

# Logging Level
RUST_LOG=auth_transition=info
