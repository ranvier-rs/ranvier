  "deprecations": [
    {
      "prefix": "ranvier_core::static_gen::StaticNode",
      "replacement": "ranvier_core::static_gen::StaticAxon",
      "removal_condition": "No supported example or published consumer uses StaticNode for two consecutive supported minor releases.",
      "earliest_removal": "0.54.0"
    },
    {
      "prefix": "ranvier_core::static_gen::write_json_file",
      "replacement": "serde_json plus application-owned filesystem I/O",
      "removal_condition": "Internal callers are removed and the migration note has shipped for two supported minor releases.",
      "earliest_removal": "0.54.0"
    },
    {
      "prefix": "ranvier_core::static_gen::read_json_file",
      "replacement": "serde_json plus application-owned filesystem I/O",
      "removal_condition": "Internal callers are removed and the migration note has shipped for two supported minor releases.",
      "earliest_removal": "0.54.0"
    },
    {
      "prefix": "ranvier_compliance::XorEncryption",
      "replacement": "an application-supplied authenticated-encryption hook such as AES-GCM or ChaCha20Poly1305",
      "removal_condition": "The xor-demo feature has no supported consumer and security migration guidance is published.",
      "earliest_removal": "0.53.0"
    }
  ]
