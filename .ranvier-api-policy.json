        { "prefix": "ranvier_core::never::Never", "tier": "Stable Candidate" }
      ],
      "boundaries": [
        { "prefix": "ranvier_core::bus", "kind": "runtime-type-erased-resource" },
        { "prefix": "ranvier_core::outcome::Outcome::into_result", "kind": "lossy-linear-result-adapter" },
